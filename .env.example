# --- Database ---
# Supabase Postgres pooled connection string (puerto 6543 con pgbouncer recomendado)
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@db.xxxxx.supabase.co:5432/postgres

# --- SIPRI (fuente de scraping) ---
SIPRI_BASE_URL=https://sipri.juntadeandalucia.es

# --- Servicios externos ---
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
OSRM_BASE_URL=https://router.project-osrm.org

# --- App ---
USER_AGENT=InterinosBot/1.0 (+https://github.com/gcinc91/interinos-backend)
CORS_ORIGIN=http://localhost:5173,https://REPLACE_ME.vercel.app
ADMIN_TOKEN=change-me-to-a-long-random-string
LOG_LEVEL=INFO

# --- Scheduler ---
SCRAPE_CRON=0 */6 * * *
